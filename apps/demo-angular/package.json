{
  "name": "demo-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test:e2e": "playwright test",
    "typecheck": "ng build --configuration production"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@10.17.0",
  "dependencies": {
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@domternal/angular": "workspace:*",
    "@domternal/core": "workspace:*",
    "@domternal/extension-code-block-lowlight": "workspace:*",
    "@domternal/extension-details": "workspace:*",
    "@domternal/extension-emoji": "workspace:*",
    "@domternal/extension-image": "workspace:*",
    "@domternal/extension-table": "workspace:*",
    "lowlight": "^3.0.0",
    "@domternal/theme": "workspace:*",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.4",
    "@angular/cli": "^21.2.4",
    "@angular/compiler-cli": "^21.2.4",
    "@playwright/test": "^1.58.2",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}