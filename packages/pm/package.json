      "import": "./src/dropcursor.js",
      "require": "./src/dropcursor.cjs",
      "types": "./src/dropcursor.d.ts"
    },
    "./gapcursor": {
      "import": "./src/gapcursor.js",
      "require": "./src/gapcursor.cjs",
      "types": "./src/gapcursor.d.ts"
    },
    "./history": {
      "import": "./src/history.js",
      "require": "./src/history.cjs",
      "types": "./src/history.d.ts"
    },
    "./inputrules": {
      "import": "./src/inputrules.js",
      "require": "./src/inputrules.cjs",
      "types": "./src/inputrules.d.ts"
